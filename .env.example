# IIFL Broker Credentials
IIFL_USERNAME=your_client_code
IIFL_PASSWORD=your_password
IIFL_API_KEY=your_api_key
IIFL_API_SECRET=your_api_secret

# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Trading Configuration
TRADING_MODE=paper  # paper or live
SYMBOL=NIFTY
TIMEFRAME=5  # minutes
FAST_EMA=9
SLOW_EMA=21
RSI_PERIOD=14
RSI_OVERBOUGHT=70
RSI_OVERSOLD=30
ATR_PERIOD=14
ADX_PERIOD=14

# Risk Management
DAILY_LOSS_LIMIT=3000  # in rupees
LOT_SIZE=1
QUANTITY=1

# Trading Hours (IST)
START_HOUR=9
START_MINUTE=15
STOP_NEW_ENTRIES_HOUR=15
STOP_NEW_ENTRIES_MINUTE=15
SQUARE_OFF_HOUR=15
SQUARE_OFF_MINUTE=30

# Options Configuration (if trading options)
OPTIONS_EXPIRY=weekly  # weekly or monthly
STRIKE_OFFSET=0
OPTION_TYPE=CE  # CE or PE

# Logging
LOG_LEVEL=INFO
DATABASE_PATH=./data/trading.db
LOG_PATH=./logs
